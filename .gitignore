# Dataset (no se versionan imágenes ni datos pesados)
data/raw/
data/processed/

# Imágenes (del dataset; no se versionan)
*.jpg
*.jpeg
*.png

# Excepción: los assets de la app SÍ se versionan (logo, etc.), necesarios en deploy.
!prod/assets/
!prod/assets/**

# Pesos de modelos (.pth). Por defecto NO se versionan: son pesados y reproducibles.
# Excepción: el modelo final de producción, que sí se versiona vía Git LFS.
*.pth
!dev/modelo.pth

# Checkpoints de experimentos (locales, ~450 MB; reproducibles desde el notebook).
dev/models_02/

# Python
__pycache__/
*.pyc

# Jupyter
.ipynb_checkpoints/

# Entornos virtuales
venv/
.venv/
env/

# Variables de entorno / secretos locales
.env

# Sistema operativo
.DS_Store
Thumbs.db

# Documentos / consignas que no se versionan
TP_Integrador_2026.pdf

# Caché de descarga del modelo en producción (se baja desde MODEL_URL en runtime).
prod/*.part

# Secrets de Streamlit (NO versionar el real; sí se versiona el .example).
.streamlit/secrets.toml
