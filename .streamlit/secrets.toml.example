# Ejemplo de secrets de Streamlit.
#
# Copiá este archivo a ".streamlit/secrets.toml" (SIN el sufijo .example) y
# completá el valor real. El archivo secrets.toml NO se versiona (está en
# .gitignore) para no filtrar URLs/credenciales en el repositorio.
#
# MODEL_URL: enlace de DESCARGA DIRECTA al modelo entrenado (modelo.pth, ~158 MB).
# La app (prod/utils.py) lo usa cuando el archivo no está disponible localmente
# —por ejemplo en Streamlit Community Cloud, que no resuelve los punteros de
# Git LFS—, descargándolo a una caché local al iniciar.
#
# Ejemplos de host con descarga directa:
#   - Hugging Face:   https://huggingface.co/<usuario>/<repo>/resolve/main/modelo.pth
#   - GitHub Release: https://github.com/<owner>/<repo>/releases/download/<tag>/modelo.pth
#
# En Streamlit Community Cloud, además de (o en lugar de) este archivo, podés
# definir MODEL_URL en: App -> Settings -> Secrets.

MODEL_URL = "https://ejemplo.com/ruta/al/modelo.pth"
